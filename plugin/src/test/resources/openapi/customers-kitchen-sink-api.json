{
  "openapi": "3.1.0",
  "info": {
    "title": "Kitchen Sink API",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "Address": {
        "type": "object",
        "required": ["city", "zip"],
        "properties": {
          "city": { "type": "string", "minLength": 1, "maxLength": 60 },
          "zip": { "type": "string", "pattern": "^[0-9]{5}$" }
        }
      },
      "BasicInfo": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "Contact": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "pattern": "^.+@.+$" },
          "phone": { "type": "string", "nullable": true }
        }
      }
    }
  },
  "paths": {
    "/customers/kitchen-sink": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "age",
                  "balance",
                  "billingAddress",
                  "birthDate",
                  "createdAt",
                  "enabled",
                  "handle",
                  "identification",
                  "loyaltyOrPromo",
                  "loyaltyPoints",
                  "newsletterConsent",
                  "notes",
                  "openAt",
                  "paymentMethod",
                  "profile",
                  "status",
                  "tags",
                  "tier"
                ],
                "properties": {
                  "age": { "type": "integer", "minimum": 0, "maximum": 120 },
                  "balance": { "type": "number" },
                  "loyaltyPoints": { "type": "integer", "minimum": 0, "multipleOf": 100 },
                  "enabled": { "type": "boolean" },
                  "newsletterConsent": { "type": "boolean" },
                  "handle": { "type": "string", "minLength": 3, "maxLength": 20, "pattern": "^[a-z][a-z0-9]+$" },
                  "status": { "type": "string", "enum": ["active", "inactive"] },
                  "tier": { "type": "string", "nullable": true, "enum": ["bronze", "silver", "gold"] },
                  "birthDate": { "type": "string", "format": "date" },
                  "createdAt": { "type": "string", "format": "date-time" },
                  "openAt": { "type": "string", "format": "time" },
                  "tags": { "type": "array", "minItems": 1, "maxItems": 4, "items": { "type": "string" } },
                  "notes": { "type": "array", "items": { "type": "string" } },
                  "profile": {
                    "type": "object",
                    "allOf": [
                      { "$ref": "#/components/schemas/BasicInfo" },
                      { "$ref": "#/components/schemas/Contact" }
                    ]
                  },
                  "billingAddress": { "$ref": "#/components/schemas/Address" },
                  "shippingAddress": { "$ref": "#/components/schemas/Address" },
                  "shippingCarrier": { "type": "string" },
                  "paymentMethod": { "type": "string", "enum": ["card", "invoice"] },
                  "cardNumber": { "type": "string", "pattern": "^[0-9]{16}$" },
                  "identification": {
                    "type": "object",
                    "oneOf": [
                      { "type": "object", "required": ["passportNumber"], "properties": { "passportNumber": { "type": "string" } } },
                      { "type": "object", "required": ["driversLicense"], "properties": { "driversLicense": { "type": "string" } } }
                    ]
                  },
                  "loyaltyOrPromo": {
                    "type": "object",
                    "anyOf": [
                      { "type": "object", "required": ["loyaltyId"], "properties": { "loyaltyId": { "type": "string" } } },
                      { "type": "object", "required": ["promoCode"], "properties": { "promoCode": { "type": "string" } } }
                    ]
                  }
                },
                "dependentRequired": {
                  "shippingAddress": ["shippingCarrier"]
                },
                "if": {
                  "properties": { "paymentMethod": { "const": "card" } },
                  "required": ["paymentMethod"]
                },
                "then": {
                  "required": ["cardNumber"]
                }
              }
            }
          }
        }
      }
    }
  }
}
