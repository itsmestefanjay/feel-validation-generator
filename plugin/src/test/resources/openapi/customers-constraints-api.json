{
  "openapi": "3.0.1",
  "info": {
    "title": "Constraint Coverage API",
    "version": "1.0.0"
  },
  "paths": {
    "/customers/constraints": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "code",
                  "handle",
                  "notes",
                  "tags"
                ],
                "properties": {
                  "code": {
                    "type": "string",
                    "pattern": "^[A-Z]{3}$"
                  },
                  "handle": {
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 8
                  },
                  "notes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "tags": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 3,
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
