{
  "openapi": "3.1.0",
  "info": {
    "title": "Conditional Nested Required API",
    "version": "1.0.0"
  },
  "paths": {
    "/orders": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "needsDelivery": {
                    "type": "boolean"
                  },
                  "delivery": {
                    "type": "object",
                    "required": ["address"],
                    "properties": {
                      "address": { "type": "string" }
                    }
                  }
                },
                "if": {
                  "properties": {
                    "needsDelivery": { "const": true }
                  },
                  "required": ["needsDelivery"]
                },
                "then": {
                  "required": ["delivery"]
                }
              }
            }
          }
        }
      }
    }
  }
}
